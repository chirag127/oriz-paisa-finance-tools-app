---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'
import { AccountPanel } from '@chirag127/oriz-ui'
import '~/lib/firebase'
---

<BaseLayout
  title={`Account — ${SITE_CONFIG.name}`}
  description={`Sign in to ${SITE_CONFIG.name}. One account works across every oriz site.`}
  noindex={true}
  withSidebar={false}
>
  <header class="container-prose page-head">
    <p class="eyebrow"><a href="/">{SITE_CONFIG.name}</a> / Account</p>
    <h1>Account</h1>
    <p class="lede">
      One sign-in works across every oriz site. Saved scenarios and bookmarks
      follow you.
    </p>
  </header>

  <section class="container-prose">
    <AccountPanel client:load siteName={SITE_CONFIG.name} />
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: 3rem 1.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; letter-spacing: -0.02em; margin: 0; }
  .lede { color: var(--color-fg-muted); margin: 0.75rem 0 0; font-size: 1.0625rem; max-width: 56ch; }
</style>
