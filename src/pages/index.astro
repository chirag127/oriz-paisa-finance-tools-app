---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG, SITE_EMOJI } from '~/lib/siteConfig'
import { FAMILY } from '@chirag127/oriz-ui'
import SIPCalculator from '~/components/calculators/SIPCalculator.tsx'
import EMICalculator from '~/components/calculators/EMICalculator.tsx'

const calculatorGroups = [
  {
    title: 'Investments',
    items: ['SIP', 'Lumpsum', 'Step-up SIP', 'SWP', 'CAGR / XIRR', 'Goal planner', 'FIRE'],
  },
  {
    title: 'Loans & EMI',
    items: ['Home loan EMI', 'Car loan', 'Personal loan', 'Prepayment impact', 'Loan comparison', 'Eligibility / FOIR'],
  },
  {
    title: 'Banking & savings',
    items: ['FD', 'RD', 'PPF', 'NPS', 'NSC', 'SSY', 'Compound interest'],
  },
  {
    title: 'Tax & salary',
    items: ['Take-home (CTC → in-hand)', 'TDS', 'HRA exemption', 'Gratuity', 'Leave encashment', 'GST'],
  },
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${SITE_CONFIG.name} — oriz`,
  url: SITE_CONFIG.origin,
  description: SITE_CONFIG.description,
  publisher: { '@type': 'Person', name: FAMILY.operator.name, url: `${FAMILY.rootOrigin}/about/` },
}
---

<BaseLayout jsonLd={jsonLd}>
  <section class="hero container-page">
    <p class="eyebrow">{SITE_EMOJI} Part of the <a href={FAMILY.rootOrigin}>oriz</a> family</p>
    <h1 class="hero-h">
      Calculators that <span class="hero-accent">show the math</span>.
    </h1>
    <p class="hero-lede">
      {SITE_CONFIG.tagline}. Every input mapped to every output, with the formula
      on screen — not a black box. Math runs in your browser; nothing leaves your device.
    </p>
    <div class="hero-cta">
      <a href="#sip" class="btn btn-primary">Try the SIP calculator →</a>
      <a href="#catalogue" class="btn">Browse all calculators</a>
    </div>
  </section>

  <section id="sip" class="container-page section">
    <h2 class="section-h">SIP — future value</h2>
    <p class="section-lede">
      How much will a monthly SIP grow into? Punch in the amount, expected return,
      and tenure; the formula and year-by-year breakdown are right below the result.
    </p>
    <SIPCalculator client:idle />
  </section>

  <section id="emi" class="container-page section">
    <h2 class="section-h">Home loan — EMI</h2>
    <p class="section-lede">
      Standard amortising EMI for any principal, rate, and tenure. No lead capture,
      no &ldquo;talk to an advisor&rdquo; popup — just the formula and the answer.
    </p>
    <EMICalculator client:idle />
  </section>

  <section id="catalogue" class="container-page section">
    <h2 class="section-h">Calculator catalogue</h2>
    <p class="section-lede">
      The full set lands on the sub-pages as the math is wired up. The two above
      are live; the rest follow as React islands using the same shape.
    </p>

    <div class="cat-grid">
      {calculatorGroups.map((g) => (
        <div class="cat">
          <h3 class="cat-h">{g.title}</h3>
          <ul class="cat-list">
            {g.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page section">
    <h2 class="section-h">How {SITE_CONFIG.name} stays free</h2>
    <div class="prose">
      <p>
        Every calculator is a static page. The math runs in your browser — no
        inputs ever leave your device, no account is needed to use a calculator.
        Sign-in is optional and only powers cross-site features (saved
        scenarios, bookmarks) that follow you across the oriz family.
      </p>
      <p>
        Display ads on a few pages cover the domain renewal. Nothing is gated.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding-block: 3rem 2.5rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    color: var(--color-fg-muted);
    font-size: 0.75rem;
    margin: 0 0 1rem;
  }
  .eyebrow a { color: var(--color-fg-muted); }
  .eyebrow a:hover { color: var(--color-accent); }
  .hero-h {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 1rem;
    max-width: 24ch;
  }
  .hero-accent { color: var(--color-accent); }
  .hero-lede { color: var(--color-fg-muted); font-size: 1.0625rem; max-width: 60ch; margin: 0 0 1.5rem; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.625rem; }
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    height: 40px; padding-inline: 1rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-button);
    color: var(--color-fg); font-weight: 500; text-decoration: none;
    font-size: 0.9375rem;
  }
  .btn:hover { border-color: color-mix(in oklab, var(--color-accent) 50%, var(--color-border)); color: var(--color-fg); }
  .btn-primary { background: var(--color-accent); color: var(--color-accent-fg); border-color: var(--color-accent); }
  .btn-primary:hover { color: var(--color-accent-fg); }

  .section { padding-block: 3rem; border-bottom: 1px solid var(--color-border); }
  .section:last-of-type { border-bottom: 0; }
  .section-h {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }
  .section-lede { color: var(--color-fg-muted); max-width: 64ch; margin: 0 0 2rem; font-size: 1rem; }

  .cat-grid {
    display: grid; gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }
  .cat {
    padding: 1.25rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  .cat-h {
    font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--color-fg-muted); margin: 0 0 0.75rem;
  }
  .cat-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.375rem; color: var(--color-fg); font-size: 0.9375rem; }

  .prose { color: var(--color-prose); max-width: 64ch; line-height: 1.7; }
  .prose p { margin: 0 0 1.25rem; }
</style>
