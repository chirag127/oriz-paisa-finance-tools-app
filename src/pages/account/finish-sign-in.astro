---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'
import { FinishSignIn } from '@chirag127/oriz-ui'
import '~/lib/firebase'
---

<BaseLayout
  title={`Finishing sign-in — ${SITE_CONFIG.name}`}
  description="Completing email-link sign-in."
  noindex={true}
  withSidebar={false}
>
  <section class="container-prose finish">
    <FinishSignIn client:load successPath="/account/" />
  </section>
</BaseLayout>

<style>
  .finish { padding-block: 5rem 4rem; }
</style>
