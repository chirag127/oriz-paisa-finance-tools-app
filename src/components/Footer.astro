---
import { FAMILY, FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'
const year = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="container-page footer-inner">
    <div class="footer-col">
      <p class="footer-brand">{SITE_CONFIG.name} <span class="footer-fam">— oriz</span></p>
      <p class="footer-tag">{SITE_CONFIG.tagline}.</p>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Family</h2>
      <ul class="footer-links">
        {FAMILY_SITES.map((s) => (
          <li><a href={s.url}>{s.name}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Site</h2>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href={FAMILY.rootOrigin}>oriz hub</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-h">Legal</h2>
      <ul class="footer-links">
        <li><a href="/legal/privacy/">Privacy</a></li>
        <li><a href="/legal/terms/">Terms</a></li>
        <li><a href="/legal/disclaimer/">Disclaimer</a></li>
        <li><a href="/legal/cookies/">Cookies</a></li>
        <li><a href="/legal/grievance/">Grievance officer</a></li>
      </ul>
    </div>
  </div>

  <div class="container-page sebi-strip" role="note" aria-label="SEBI disclaimer">
    <p>
      <strong>SEBI disclaimer:</strong> Calculators on this site are for educational
      purposes only. Outputs are based on user inputs and do not constitute
      investment, tax, or insurance advice. Consult a SEBI-registered investment
      advisor before making financial decisions. Past performance is not indicative
      of future returns. See the full <a href="/legal/disclaimer/">disclaimer</a>.
    </p>
  </div>

  <div class="container-page footer-bottom">
    <p>&copy; {year} {FAMILY.operator.name}. All sites built with <a href="https://github.com/chirag127/oriz">oriz</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    padding-block: 3rem 1.5rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-soft);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) { .footer-inner { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .footer-inner { grid-template-columns: 2fr 1fr 1fr 1fr; } }
  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .footer-fam { color: var(--color-fg-soft); font-size: 1rem; font-weight: 400; }
  .footer-tag { color: var(--color-fg-muted); margin: 0; max-width: 36ch; }
  .footer-h {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    margin: 0 0 0.75rem;
  }
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-links a { color: var(--color-fg-muted); text-decoration: none; font-size: 0.9375rem; }
  .footer-links a:hover { color: var(--color-fg); }
  .sebi-strip {
    margin-top: 2.5rem;
    padding: 1rem 1.5rem;
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-card);
    color: var(--color-fg-muted);
    font-size: 0.8125rem;
    line-height: 1.6;
  }
  .sebi-strip p { margin: 0; max-width: 80ch; }
  .sebi-strip a { color: var(--color-accent); }
  .footer-bottom {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-soft);
    font-size: 0.8125rem;
  }
  .footer-bottom p { margin: 0; }
</style>
