---
/**
 * SiteSidebar — wraps the @chirag127/oriz-ui Sidebar React island with the
 * finance-specific link sections. Renders inside BaseLayout's left column at
 * >=1024px and as a sheet at smaller widths.
 *
 * Sections cover the calculator catalogue:
 *   SIP / EMI / FIRE / Tax / Compounding
 * plus a Family section listing the 10 oriz sites.
 */
import { Sidebar } from '@chirag127/oriz-ui'
import type { SidebarSection } from '@chirag127/oriz-ui'
import { FAMILY_SITES } from '@chirag127/oriz-ui'
import { SITE_CONFIG } from '~/lib/siteConfig'

const sections: SidebarSection[] = [
  {
    title: 'Investments',
    links: [
      { label: 'SIP', href: '/calculators/sip/' },
      { label: 'Lumpsum', href: '/calculators/lumpsum/' },
      { label: 'Step-up SIP', href: '/calculators/step-up-sip/' },
      { label: 'SWP', href: '/calculators/swp/' },
      { label: 'CAGR / XIRR', href: '/calculators/cagr/' },
      { label: 'Goal planner', href: '/calculators/goal/' },
      { label: 'FIRE', href: '/calculators/fire/' },
    ],
  },
  {
    title: 'Loans & EMI',
    links: [
      { label: 'Home loan EMI', href: '/calculators/home-loan/' },
      { label: 'Car loan', href: '/calculators/car-loan/' },
      { label: 'Personal loan', href: '/calculators/personal-loan/' },
      { label: 'Prepayment impact', href: '/calculators/prepayment/' },
      { label: 'Loan comparison', href: '/calculators/loan-comparison/' },
      { label: 'Eligibility (FOIR)', href: '/calculators/loan-eligibility/' },
    ],
  },
  {
    title: 'Banking & savings',
    links: [
      { label: 'FD', href: '/calculators/fd/' },
      { label: 'RD', href: '/calculators/rd/' },
      { label: 'PPF', href: '/calculators/ppf/' },
      { label: 'NPS', href: '/calculators/nps/' },
      { label: 'NSC', href: '/calculators/nsc/' },
      { label: 'SSY', href: '/calculators/ssy/' },
      { label: 'Compound interest', href: '/calculators/compound/' },
    ],
  },
  {
    title: 'Tax & salary',
    links: [
      { label: 'Take-home (CTC)', href: '/calculators/take-home/' },
      { label: 'TDS', href: '/calculators/tds/' },
      { label: 'HRA exemption', href: '/calculators/hra/' },
      { label: 'Gratuity', href: '/calculators/gratuity/' },
      { label: 'Leave encashment', href: '/calculators/leave-encashment/' },
      { label: 'GST', href: '/calculators/gst/' },
    ],
  },
  {
    title: 'Family',
    links: FAMILY_SITES.map((s) => ({
      label: `${s.emoji} ${s.name}`,
      href: s.url,
    })),
  },
]
---

<Sidebar
  client:idle
  siteName={SITE_CONFIG.name}
  siteSlug={SITE_CONFIG.slug}
  sections={sections}
/>
