---
const groups = [
  { label: 'Calculators', items: [
    { href: '/calculators/sip/', label: 'SIP' },
    { href: '/calculators/emi/', label: 'EMI' },
    { href: '/calculators/tax/', label: 'Income tax' },
    { href: '/calculators/', label: 'All calculators' },
  ]},
  { label: 'Markets', items: [
    { href: '/fii-dii/', label: 'FII / DII activity' },
    { href: '/mmi/', label: 'Market Mood Index' },
  ]},
  { label: 'Guides', items: [
    { href: '/credit-cards/', label: 'Credit cards' },
    { href: '/razorpay/', label: 'Razorpay guides' },
  ]},
  { label: 'Account', items: [{ href: '/settings/', label: 'Settings' }]},
]
---
{groups.map(g => (<section><h3>{g.label}</h3><ul>{g.items.map(i => <li><a href={i.href}>{i.label}</a></li>)}</ul></section>))}
